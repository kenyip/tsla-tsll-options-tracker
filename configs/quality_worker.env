# Quality worker sprint profile — EDGE throughput for multi-day push.
# Sourced by scripts/trader_quality_worker.sh and `just trader-quality-worker`.
# Never enables live/arm.

# Seconds between cycles (was 20)
TRADER_QUALITY_SLEEP=5

# Parallel prove slots (M4 10-core; phase uses ≤4 subprocesses)
TRADER_QC_PARALLEL=4

# When paper book is full (2/2), skip heavy campaign most cycles (~200s each).
# Always campaign when book has room for a new open.
TRADER_QC_PAPER_EVERY=3
TRADER_QC_CAMPAIGN_EVERY=3

# Slightly wider CSP search (first-live MCP lane) + stress batch
TRADER_QC_TOP_CSP=8
TRADER_QC_MUT_CSP=2
TRADER_QC_TOP_DR=8
TRADER_QC_MUT_DR=3
TRADER_QC_STRESS_LIMIT=8
TRADER_QC_STRESS_LEADERS=2

# Safety
TRADER_QC_FORCE_PAPER=0
